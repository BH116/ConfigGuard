{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "outDir": "dist/cjs",
    "declaration": true,
    "declarationDir": "dist/types",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "noEmit": false
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules", "lib/utils.ts", "lib/fixtures/**/*"]
}
