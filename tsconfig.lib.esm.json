{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist/esm",
    "declaration": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "noEmit": false
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules", "lib/utils.ts", "lib/fixtures/**/*"]
}
